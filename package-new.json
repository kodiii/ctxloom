{
  "name": "contextmesh",
  "version": "1.0.0",
  "description": "ContextMesh — The Universal Code Context Engine. A local-first MCP sidecar providing intelligent code context via hybrid Vector + AST + Graph search with Skeletonization.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "contextmesh": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "context-engine",
    "code-search",
    "ast",
    "skeletonization"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@lancedb/lancedb": "^0.27.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^4.0.0",
    "tree-sitter-typescript": "^0.23.0",
    "web-tree-sitter": "^0.25.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
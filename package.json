{
  "name": "ctxloom-pro",
  "version": "1.0.13",
  "description": "ctxloom — The Universal Code Context Engine. A local-first MCP server providing intelligent code context via hybrid Vector + AST + Graph search with Skeletonization (92% token reduction).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ctxloom": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "apps/dashboard/dist/**/*",
    "!apps/dashboard/dist/**/*.map",
    "apps/dashboard/package.json",
    "LICENSE"
  ],
  "scripts": {
    "clean:src": "node scripts/clean-stale-src-artifacts.mjs",
    "prebuild": "npm run clean:src",
    "build": "tsup && npm run -w @ctxloom/dashboard build",
    "prebuild:cli": "npm run clean:src",
    "build:cli": "tsup",
    "build:dashboard": "npm run -w @ctxloom/dashboard build",
    "prepublishOnly": "tsup && npm run -w @ctxloom/dashboard build && node scripts/publish-smoke-test.mjs",
    "smoke:publish": "node scripts/publish-smoke-test.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "pretest": "npm run clean:src",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "postinstall": "node dist/setup/postinstall.js || true",
    "bench:repos": "tsx benchmarks/benchmark-public-repos.ts",
    "e2e:corpus": "node e2e-corpus/run.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "code-context",
    "code-review",
    "blast-radius",
    "architecture",
    "dependency-graph",
    "call-graph",
    "community-detection",
    "wiki-generation",
    "tree-sitter",
    "ast",
    "monorepo",
    "semantic-search",
    "skeletonization",
    "vector-search",
    "local-first",
    "typescript",
    "python",
    "rust",
    "golang",
    "java"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/kodiii/ctxloom"
  },
  "homepage": "https://github.com/kodiii/ctxloom/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/kodiii/ctxloom/issues"
  },
  "author": "Codzign",
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@lancedb/lancedb": "^0.27.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^4.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "js-yaml": "^4.1.1",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "simple-git": "^3.36.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.25.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@ctxloom/core": "*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "apache-arrow": "^18.1.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
